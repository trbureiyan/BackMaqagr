{
  "info": {
    "_postman_id": "f62f71f5-8af9-4cf8-8cc4-1f4f6f505f01",
    "name": "MaqAgr Backend",
    "description": "Coleccion completa de endpoints del backend MaqAgr. Incluye auth, catalogos, terrenos, calculos, recomendaciones, notificaciones, admin, health, roles y exportaciones.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requestUrl = pm.request.url.toString();",
          "const isAuthLogin = requestUrl.includes('/api/auth/login');",
          "const isAuthRegister = requestUrl.includes('/api/auth/register');",
          "const hasToken = !!pm.environment.get('token');",
          "",
          "if (!hasToken && !isAuthLogin && !isAuthRegister) {",
          "  const baseUrl = pm.environment.get('baseUrl');",
          "  const loginEmail = pm.environment.get('loginEmail');",
          "  const loginPassword = pm.environment.get('loginPassword');",
          "",
          "  if (baseUrl && loginEmail && loginPassword) {",
          "    pm.sendRequest({",
          "      url: baseUrl + '/api/auth/login',",
          "      method: 'POST',",
          "      header: { 'Content-Type': 'application/json' },",
          "      body: {",
          "        mode: 'raw',",
          "        raw: JSON.stringify({ email: loginEmail, password: loginPassword })",
          "      }",
          "    }, function (err, res) {",
          "      if (!err && res && res.code === 200) {",
          "        const json = res.json();",
          "        if (json && json.data && json.data.token) {",
          "          pm.environment.set('token', json.data.token);",
          "          pm.environment.set('refreshToken', json.data.token);",
          "          if (json.data.user && json.data.user.user_id) {",
          "            pm.environment.set('userId', json.data.user.user_id);",
          "          }",
          "        }",
          "      }",
          "    });",
          "  }",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Status code is not 5xx', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});",
          "",
          "const contentType = pm.response.headers.get('Content-Type') || '';",
          "if (contentType.includes('application/json')) {",
          "  pm.test('Response JSON is parseable', function () {",
          "    pm.expect(() => pm.response.json()).to.not.throw();",
          "  });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "terrainId", "value": "1" },
    { "key": "tractorId", "value": "1" },
    { "key": "implementId", "value": "1" },
    { "key": "recommendationId", "value": "1" },
    { "key": "notificationId", "value": "1" },
    { "key": "roleId", "value": "2" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"postman.user@example.com\",\n  \"password\": \"Postman123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 201 or 409', function () {",
                "  pm.expect([201, 409]).to.include(pm.response.code);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status is 200', function () {",
                "  pm.response.to.have.status(200);",
                "});",
                "const json = pm.response.json();",
                "if (json && json.data && json.data.token) {",
                "  pm.environment.set('token', json.data.token);",
                "  pm.environment.set('refreshToken', json.data.token);",
                "}",
                "if (json && json.data && json.data.user && json.data.user.user_id) {",
                "  pm.environment.set('userId', json.data.user.user_id);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Refresh (re-login)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status is 200', function () {",
                "  pm.response.to.have.status(200);",
                "});",
                "const json = pm.response.json();",
                "if (json && json.data && json.data.token) {",
                "  pm.environment.set('token', json.data.token);",
                "  pm.environment.set('refreshToken', json.data.token);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman User Updated\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/profile"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{loginPassword}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/password"
          }
        }
      ]
