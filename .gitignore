# ═══════════════════════════════════════════════════════════
# MaqAgr Backend — .gitignore
# ═══════════════════════════════════════════════════════════

# ─── Dependencies ─────────────────────────────────────────
/node_modules/
/.pnp
.pnp.js
.yarn/
.npm/

# ─── Environment Variables ────────────────────────────────
.env
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.staging.local

# ─── Logs ─────────────────────────────────────────────────
/logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
postman-cloud-agent.log

# ─── Documentation (local only) ───────────────────────────
/docs/site/
/docs/out/
/documentation/out/
/out/
*.pdf
*.docx
*.doc
*.pptx
*.xlsx
ASIGNACION_TAREAS.md
PLAN_DESARROLLO.md
ESTRUCTURA_SCRUM_JIRA.md
SPRINT_2_PROPUESTA.md
INFORME_TÉCNICO_DEL_PROYECTO_MaqAgr.md

# ─── Testing ──────────────────────────────────────────────
/coverage/
.nyc_output/
test-results/
testing/
src/test-models.js

# ─── Postman (keep only official collections) ─────────────
postman/experimental/
postman-reports/
newman/
*.postman_collection.json
*.postman_environment.json
*.postman_globals.json
!postman/MaqAgr-Backend.postman_collection.json
!postman/MaqAgr-Dev.postman_environment.json
!postman/MaqAgr-Staging.postman_environment.json

# ─── Build / Cache ────────────────────────────────────────
/dist/
/build/
.cache/
.eslintcache
.prettiercache

# ─── Database ─────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
database/backups/
migrations/

# ─── OS / Editor ──────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.history/

# ─── Runtime ──────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock
tmp/
temp/
*.tmp

# ─── Context / AI scratch ─────────────────────────────────
/.context/

# ─── Agent Tools / Skills / AI (local only) ───────────────
skills-lock.json
.agent/
.agents/
.atl/
.claude/
.cursor/
.cursorrules

# ─── SDD / Task artifacts (local only) ────────────────────
tasks-*.json
openspec/
